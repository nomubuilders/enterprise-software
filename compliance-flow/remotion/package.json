{
  "name": "compliance-flow-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "Pitch / explainer videos for Compliance Ready AI, rendered with Remotion.",
  "scripts": {
    "copy-assets": "node scripts/copy-assets.mjs",
    "postinstall": "npm run copy-assets",
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts PitchVideo out/pitch.mp4",
    "render:webm": "remotion render src/index.ts PitchVideo out/pitch.webm --codec=vp9",
    "render:still": "remotion still src/index.ts PitchVideo out/poster.png --frame=300"
  },
  "dependencies": {
    "@mediabunny/ac3": "1.42.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
