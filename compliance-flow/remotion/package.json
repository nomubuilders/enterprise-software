    "@remotion/animated-emoji": "4.0.454",
    "@remotion/animation-utils": "4.0.454",
    "@remotion/captions": "4.0.454",
    "@remotion/cli": "^4.0.200",
    "@remotion/cloudrun": "4.0.454",
    "@remotion/elevenlabs": "4.0.454",
    "@remotion/enable-scss": "4.0.454",
    "@remotion/fonts": "4.0.454",
    "@remotion/gif": "4.0.454",
    "@remotion/google-fonts": "4.0.454",
    "@remotion/install-whisper-cpp": "4.0.454",
    "@remotion/lambda": "4.0.454",
    "@remotion/layout-utils": "4.0.454",
    "@remotion/licensing": "4.0.454",
    "@remotion/light-leaks": "4.0.454",
    "@remotion/lottie": "4.0.454",
    "@remotion/mcp": "4.0.454",
    "@remotion/media": "4.0.454",
    "@remotion/media-parser": "4.0.454",
    "@remotion/media-utils": "4.0.454",
    "@remotion/motion-blur": "4.0.454",
    "@remotion/noise": "4.0.454",
    "@remotion/openai-whisper": "4.0.454",
    "@remotion/paths": "4.0.454",
    "@remotion/player": "4.0.454",
    "@remotion/player-a11y": "4.0.454",
    "@remotion/preload": "4.0.454",
    "@remotion/renderer": "4.0.454",
    "@remotion/rive": "4.0.454",
    "@remotion/rounded-text-box": "4.0.454",
    "@remotion/sfx": "4.0.454",
    "@remotion/shapes": "4.0.454",
    "@remotion/skia": "4.0.454",
    "@remotion/starburst": "4.0.454",
    "@remotion/studio": "4.0.454",
    "@remotion/tailwind": "4.0.454",
    "@remotion/tailwind-v4": "4.0.454",
    "@remotion/three": "4.0.454",
    "@remotion/transitions": "4.0.454",
    "@remotion/vercel": "4.0.454",
    "@remotion/webcodecs": "4.0.454",
    "@remotion/whisper-web": "4.0.454",
    "@remotion/zod-types": "4.0.454",
    "@remotion/zod-types-v3": "4.0.454",
    "culori": "^4.0.2",
    "mediabunny": "1.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.200",
    "remotion-bits": "^0.2.0",
    "three": "^0.182.0",
